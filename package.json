{
  "name": "yt-music-bot",
  "version": "1.0.0",
  "description": "A Discord music bot built with TypeScript that streams music from YouTube",
  "scripts": {
    "start": "tsx src/main.ts",
    "lint:check": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "dev": "tsx watch src/main.ts",
    "typecheck": "tsc --noEmit"
  },
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "@discordjs/opus": "0.10.0",
    "@discordjs/voice": "0.19.0",
    "@snazzah/davey": "0.1.10",
    "chalk": "5.6.2",
    "discord.js": "14.25.1",
    "dotenv": "17.3.1",
    "ffmpeg-static": "5.3.0",
    "youtubei.js": "16.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.3.3",
    "eslint": "10.0.2",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  },
  "engines": {
    "node": "22.13.1"
  }
}
